# App
APP_NAME=AlloyDB Semantic Search API
APP_ENV=dev

# Vertex AI embeddings
GCP_PROJECT_ID=PROJECT_ID
GCP_REGION=us-central1
EMBEDDING_MODEL=text-embedding-004

# Vector settings
VECTOR_DIM=768

# AlloyDB connector (recommended for Cloud Run)
USE_ALLOYDB_CONNECTOR=true
ALLOYDB_INSTANCE_URI=projects/PROJECT_ID/locations/REGION/clusters/CLUSTER/instances/INSTANCE
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=appdb

# Optional direct DB URL (only used if USE_ALLOYDB_CONNECTOR=false)
# DATABASE_URL=postgresql+pg8000://postgres:password@127.0.0.1:5432/appdb
