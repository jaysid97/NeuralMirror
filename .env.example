# ─── NeuralMirror — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your real keys.
# NEVER commit the actual .env to Git.

# Murf Text-to-Speech API
MURF_API_KEY=your_murf_api_key_here
MURF_VOICE_ID=en-US-natalie
MURF_MODEL=FALCON
MURF_REGION=GLOBAL
MURF_LOCALE=en-US

# OpenAI / OpenAI-compatible LLM
OPENAI_API_KEY=your_openai_api_key_here
# Optional: use another OpenAI-compatible provider endpoint (example: OpenRouter)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Optional: choose a model supported by your provider/account
# LLM_MODEL=openai/gpt-4o-mini
#
# Recommended low/no-cost setup (provider-dependent availability):
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
